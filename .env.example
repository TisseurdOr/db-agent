# LLM API（兼容 Anthropic SDK，可换 OpenAI / Kimi / DeepSeek 等）
ANTHROPIC_API_KEY=sk-your-key-here
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_MODEL=deepseek-chat

# Eval 独立评测模型（建议用和被评 Agent 不同的模型，避免自评偏差）
KIMI_API_KEY=sk-your-kimi-key
KIMI_BASE_URL=https://api.moonshot.cn/anthropic
KIMI_MODEL=kimi-k2.5

# Embedding（用于向量记忆的语义检索）
EMBEDDING_API_KEY=sk-your-dashscope-key

# 默认用户角色（viewer / analyst / dba / manager / support）
AGENT_USER=viewer

# Token 预算——上下文窗口软预算，超 70% 触发压缩
TOKEN_BUDGET_MAX=32000
TOKEN_BUDGET_WARN=0.7

# 压缩摘要用便宜模型
COMPRESS_MODEL=deepseek-v4-flash

# Tool 返回结果最大字符数，超出截断
TOOL_RESULT_MAX_LEN=8000
