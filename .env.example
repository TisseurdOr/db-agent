# 主 Agent（对话 + 工具调用）
ANTHROPIC_API_KEY=sk-your-deepseek-key
ANTHROPIC_MODEL=deepseek-chat
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# HyDE 专用（通义最便宜档 qwen-flash），OpenAI 兼容
# 可不单独配：代码会自动复用 EMBEDDING_API_KEY
HYDE_API_KEY=sk-your-dashscope-key
HYDE_MODEL=qwen-flash
HYDE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Embedding（通义千问）
EMBEDDING_API_KEY=sk-your-dashscope-key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=qwen3.7-text-embedding

# Kimi / Moonshot（暂存备用，当前代码未读取）
KIMI_API_KEY=sk-your-kimi-key
KIMI_MODEL=kimi-k2.5
KIMI_BASE_URL=https://api.moonshot.cn/anthropic
